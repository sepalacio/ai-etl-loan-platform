# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:5173
BODY_LIMIT_MB=25
APP_URL=http://localhost:5173
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=loanpro

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=loanpro-documents

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Mailtrap recommended for local dev) ────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@loanpro.dev

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
